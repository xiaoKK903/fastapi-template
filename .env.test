# 基础配置
ENVIRONMENT=test
PROJECT_NAME="Full Stack FastAPI Project (Test)"
STACK_NAME=full-stack-fastapi-project-test
DOMAIN=test.example.com

# 前端配置
FRONTEND_HOST=http://localhost:5174
VITE_API_URL=http://localhost:8001

# 后端安全配置
SECRET_KEY=test_env_secret_key_please_change_in_production_1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z7a8b9c0d1e2f3g4h5i6j7k8l9m0n1o2p3q4r5s6t7u8v9w0x1y2z3a4b5c6d7e8f9g0h1i2j3k4l5m6n7o8p9q0r1s2t3u4v5w6x7y8z9
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CORS 配置
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5174,https://localhost,https://localhost:5174"

# 数据库配置
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=app_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_test_env

# 初始超级用户配置
