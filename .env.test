# 文件存储配置
STORAGE_PATH=./storage_test
MAX_FILE_SIZE=104857600
DEFAULT_STORAGE_QUOTA=2147483648
SHARE_LINK_EXPIRE_HOURS=24

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs
LOG_MAX_SIZE=100
LOG_BACKUP_COUNT=5

# Sentry 配置
SENTRY_DSN=

# Docker 镜像配置
DOCKER_IMAGE_BACKEND=backend-test
DOCKER_IMAGE_FRONTEND=frontend-test
TAG=test
