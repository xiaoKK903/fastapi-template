# ==============================================================================
# 环境变量配置模板
# ==============================================================================
# 请根据实际环境复制此文件并修改对应值：
# - 本地开发: 复制为 .env.local
# - 测试环境: 复制为 .env.test
# - 生产环境: 复制为 .env.production (或直接设置环境变量)
# ==============================================================================

# ==============================================================================
# 基础配置
# ==============================================================================
# 环境类型: local | test | staging | production
ENVIRONMENT=local

# 项目名称
PROJECT_NAME="Full Stack FastAPI Project"

# Docker 堆栈名称（用于 Traefik）
STACK_NAME=full-stack-fastapi-project

# 域名（用于 Traefik 和生成链接）
DOMAIN=localhost

# ==============================================================================
# 前端配置
# ==============================================================================
# 前端主机地址（用于后端生成邮件中的链接）
FRONTEND_HOST=http://localhost:5173

# 前端 API 地址（构建时使用）
VITE_API_URL=http://localhost:8000

# ==============================================================================
# 后端安全配置
# ==============================================================================
# 密钥（生产环境必须修改！）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# 访问令牌过期时间（分钟）
# 默认: 60 * 24 * 8 = 8 天
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ==============================================================================
# CORS 配置
# ==============================================================================
# 允许的跨域来源（逗号分隔）
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,https://localhost,https://localhost:5173,https://localhost:5174"

# ==============================================================================
# 数据库配置
# ==============================================================================
# PostgreSQL 服务器地址
POSTGRES_SERVER=localhost

# PostgreSQL 端口
POSTGRES_PORT=5432

# PostgreSQL 数据库名称
POSTGRES_DB=app

# PostgreSQL 用户名
POSTGRES_USER=postgres

# PostgreSQL 密码（生产环境必须修改！）
POSTGRES_PASSWORD=changethis

# ==============================================================================
# 初始超级用户配置
# ==============================================================================
# 初始超级用户邮箱
FIRST_SUPERUSER=admin@example.com

# 初始超级用户密码（生产环境必须修改！）
FIRST_SUPERUSER_PASSWORD=changethis

# ==============================================================================
# 邮件配置
# ==============================================================================
# SMTP 服务器地址
SMTP_HOST=

# SMTP 端口
SMTP_PORT=587

# SMTP 用户名
SMTP_USER=

# SMTP 密码
SMTP_PASSWORD=

# 是否使用 TLS
SMTP_TLS=True

# 是否使用 SSL
SMTP_SSL=False

# 发件人邮箱
EMAILS_FROM_EMAIL=info@example.com

# 发件人名称（可选，默认使用项目名称）
EMAILS_FROM_NAME=

# 邮件重置令牌过期时间（小时）
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# 测试邮箱（用于自动化测试）
EMAIL_TEST_USER=test@example.com

# ==============================================================================
# 文件存储配置
# ==============================================================================
# 存储路径
STORAGE_PATH=./storage

# 最大文件大小（字节，默认 100MB）
MAX_FILE_SIZE=104857600

# 允许的文件扩展名
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp,svg,pdf,doc,docx,xls,xlsx,ppt,pptx,txt,md,json,csv,xml,yaml,yml,zip,rar,7z,tar,gz,mp4,mp3,wav,avi,mkv,mov

# 默认存储配额（字节，默认 2GB）
DEFAULT_STORAGE_QUOTA=2147483648

# 分享链接过期时间（小时）
SHARE_LINK_EXPIRE_HOURS=24

# ==============================================================================
# 日志配置
# ==============================================================================
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# 日志路径（相对于 backend 目录）
LOG_PATH=./logs

# 日志文件最大大小（MB）
LOG_MAX_SIZE=50

# 日志文件保留数量
LOG_BACKUP_COUNT=10

# ==============================================================================
# Sentry 配置（可选）
# ==============================================================================
# Sentry DSN（留空则不启用）
SENTRY_DSN=

# ==============================================================================
# Docker 镜像配置
# ==============================================================================
# 后端镜像名称
DOCKER_IMAGE_BACKEND=backend

# 前端镜像名称
DOCKER_IMAGE_FRONTEND=frontend

# 镜像标签
TAG=latest
